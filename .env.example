# MySql DB Vars
DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/shoppiq_schema
DATASOURCE_USERNAME=db_username
DATASOURCE_PASSWORD=db_password

# Google OAuth Vars
GOOGLE_CLIENT_ID=google_client_id
GOOGLE_CLIENT_SECRET=google_client_secret

# Security Vars
JWT_SECRET=jwt_secret

RAZORPAY_KEY_ID=test_id
RAZORPAY_KEY_SECRET=test_key

# Email Configuration
EMAIL_PROVIDER=smtp
EMAIL_FROM=email_address
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=tls_port
SMTP_USERNAME=google_email
SMTP_PASSWORD=google_email_app_password

# Shoppiq AI-Service Vars
AI_SERVICE_ENABLED=true
AI_NVIDIA_API_KEY=nv_nmi_api_key

# RAG vector store Vars | Qdrant — docker-compose service
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_COLLECTION=shoppiq_products